{
  "expo": {
    "name": "Infinity Finances",
    "slug": "infinity-finances",
    "scheme": "infinityfinances",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.infinitefinances.app",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.infinitefinances.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#008c8e"
      }
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7092f94d-5830-4ef9-ab0b-f2aff987c287"
      }
    },
    "owner": "sravan4262"
  }
}
